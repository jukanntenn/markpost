services:
  frontend:
    image: 192.168.5.50:5000/markpost-web:{{ image_tag }}
    container_name: {{ app_name }}-frontend
    ports:
      - "8089:3000"
    environment:
      - API_PROXY_TARGET=http://backend:7330
    depends_on:
      backend:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://127.0.0.1:3000/health"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 15s
    restart: always

  backend:
    image: 192.168.5.50:5000/markpost:{{ image_tag }}
    container_name: {{ app_name }}-backend
    volumes:
      - {{ config_file }}:/app/markpost.toml:ro
    depends_on:
      postgres:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://127.0.0.1:7330/api/v1/health"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 30s
    restart: always

  postgres:
    image: postgres:17-alpine
    container_name: {{ app_name }}-postgres
    ports:
      - "5433:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    environment:
      - POSTGRES_DB={{ postgres_db }}
      - POSTGRES_USER={{ postgres_user }}
      - POSTGRES_PASSWORD={{ postgres_password }}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ postgres_user }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: always

volumes:
  pgdata:
