{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "go",
      "args": ["run", "./cmd/server"],
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "MARKPOST_JWT__ACCESS_SIGNING_KEY": "dev-access-secret-key-change-in-production",
          "MARKPOST_JWT__REFRESH_SIGNING_KEY": "dev-refresh-secret-key-change-in-production"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false,
        "group": "dev-servers"
      },
      "problemMatcher": [],
      "isBackground": true,
      "icon": { "id": "server", "color": "terminal.ansiGreen" }
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false,
        "group": "dev-servers"
      },
      "problemMatcher": [],
      "isBackground": true,
      "icon": { "id": "zap", "color": "terminal.ansiYellow" }
    },
    {
      "label": "Start All",
      "dependsOn": ["Start Backend", "Start Frontend"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "icon": { "id": "rocket", "color": "terminal.ansiBlue" }
    }
  ]
}
