COMPOSE_PROJECT_NAME=markpost

MARKPOST_SERVER__PORT=7330
FRONTEND_PORT=3034

MARKPOST_DEBUG=true
MARKPOST_DB__DRIVER=postgresql
MARKPOST_DB__DSN=postgres://markpost:markpost@postgres:5432/markpost?sslmode=disable
MARKPOST_JWT__ACCESS_SIGNING_KEY=dev-access-secret-key-change-in-production
MARKPOST_JWT__REFRESH_SIGNING_KEY=dev-refresh-secret-key-change-in-production
MARKPOST_ADMIN__INITIAL_USERNAME=markpost
MARKPOST_ADMIN__INITIAL_PASSWORD=markpost

POSTGRES_DB=markpost
POSTGRES_USER=markpost
POSTGRES_PASSWORD=markpost
POSTGRES_PORT=5432
