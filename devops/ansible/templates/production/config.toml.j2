debug = false
post_key_length = 16

[server]
host = "127.0.0.1"
port = 7330
public_url = "{{ public_url }}"
# Caddy is the only direct peer. In SaaS mode this is the Cloudflare CIDRs
# (synced from https://www.cloudflare.com/ips/); the deploy-time value comes
# from production.yml: trusted_proxies.
trusted_proxies = {{ trusted_proxies }}

[db]
driver = "postgresql"
# Unix-socket connection to the sibling postgres container over the shared
# postgres-socket named volume. The path must match postgres's default
# unix_socket_directories (/var/run/postgresql) — see docker-compose.yml.
dsn = "host=/var/run/postgresql user={{ db_user | default('markpost') }} password={{ db_password }} dbname=markpost sslmode=disable"

[jwt]
access_signing_key = "{{ jwt_access_signing_key }}"
refresh_signing_key = "{{ jwt_refresh_signing_key }}"
access_token_expire = "24h"
refresh_token_expire = "720h"

[admin]
initial_username = "markpost"
initial_password = "{{ admin_password }}"

[post]
title_max_length = 500
body_max_bytes = 1048576
# 7 days: aligns with performance-optimization.md storage/retention estimates
# (~11 GB at 7 days). delivery.history_retention is set to match (168h).
retention_days = 7

[cors]
allow_origins = ["{{ public_url }}"]
allow_headers = ["Content-Type", "Authorization", "X-OAuth-State"]

[oauth.github]
# Empty client_id/secret disables GitHub OAuth. Set both in vault to enable.
client_id = "{{ github_client_id | default('') }}"
client_secret = "{{ github_client_secret | default('') }}"
redirect_url = "{{ public_url }}/api/v1/auth/github/callback"

[ratelimit]
# L1 read: per-IP, generous — the CDN absorbs most reads.
[ratelimit.read]
per_second = 100
burst = 200
# L2 public write: per user_id, 10/min + 1000/day cap.
[ratelimit.public_write]
per_second = 0.1666666667
burst = 20
daily_per_second = 0.0115740741
daily_burst = 1000
# L3 authenticated write: per user_id, 30/min.
[ratelimit.authed_write]
per_second = 0.5
burst = 60

[render]
enabled = true
cache_size_bytes = 134217728

[cloudflare]
# Set both to enable best-effort cache-tag purge on post deletion.
# Absent (the default) means self-hosted without Cloudflare; deletion still
# removes the origin render cache and the CDN falls back to TTL expiry.
api_token = "{{ cloudflare_api_token | default('') }}"
zone_id = "{{ cloudflare_zone_id | default('') }}"

[delivery]
body_preview_chars = 200
request_timeout = "5s"
# 32 workers cover ~106 jobs/s sustained (300 ms Feishu response).
workers = 32
queue_size = 1024
scan_interval = "1s"
# Matches post.retention_days (7 days): history must not outlive the post.
history_retention = "168h"
