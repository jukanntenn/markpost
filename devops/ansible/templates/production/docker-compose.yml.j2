services:
  markpost:
    image: {{ registry | default('192.168.5.50:5000') }}/markpost:{{ image_tag }}
    container_name: {{ app_name }}
    ports:
      - "443:7157"
    volumes:
      - {{ config_file }}:/app/config.toml:ro
      - {{ app_path }}/data:/app/data
      - {{ app_path }}/Caddyfile:/etc/caddy/Caddyfile:ro
      - {{ app_path }}/certs:/app/certs:ro
      - postgres-socket:/var/run/postgresql
    environment:
      - MARKPOST_DEBUG=false
    depends_on:
      postgres:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://127.0.0.1:7157/api/v1/health"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 30s
    restart: always

  postgres:
    image: postgres:17-alpine
    container_name: {{ app_name }}-postgres
    environment:
      - POSTGRES_DB=markpost
      - POSTGRES_USER={{ db_user | default('markpost') }}
      - POSTGRES_PASSWORD={{ db_password }}
    # -c flags layer only the 5 tuned GUCs on top of the image default
    # postgresql.conf (Decision 22; 2-core/2 GB box). The socket dir is left at
    # the image default /var/run/postgresql so the entrypoint owns its perms.
    command:
      - postgres
      - -c
      - shared_buffers=256MB
      - -c
      - max_connections=50
      - -c
      - effective_cache_size=1GB
      - -c
      - maintenance_work_mem=128MB
      - -c
      - synchronous_commit=off
    volumes:
      - pgdata:/var/lib/postgresql/data
      - postgres-socket:/var/run/postgresql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -h /var/run/postgresql -U {{ db_user | default('markpost') }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: always

volumes:
  pgdata:
  postgres-socket:
