services:
  frontend:
    image: {{ registry }}/{{ frontend_image }}:{{ image_tag }}
    container_name: {{ app_name }}-frontend
    ports:
      - "{{ frontend_port }}:3000"
    environment:
      - API_PROXY_TARGET=http://backend:{{ backend_port }}
    depends_on:
      backend:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://127.0.0.1:3000/health"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 15s
    restart: always

  backend:
    image: {{ registry }}/{{ backend_image }}:{{ image_tag }}
    container_name: {{ app_name }}-backend
    environment:
      - MARKPOST_SERVER__HOST=0.0.0.0
      - MARKPOST_SERVER__PORT={{ backend_port }}
      - MARKPOST_SERVER__PUBLIC_URL={{ public_url }}
      - MARKPOST_SERVER__TRUSTED_PROXIES={{ trusted_proxies }}
      - MARKPOST_DEBUG={{ debug }}
      - MARKPOST_DB__DRIVER=postgresql
      - MARKPOST_DB__DSN=postgres://{{ postgres_user }}:{{ postgres_password }}@postgres:5432/{{ postgres_db }}?sslmode=disable
      - MARKPOST_JWT__ACCESS_SIGNING_KEY={{ jwt_access_signing_key }}
      - MARKPOST_JWT__REFRESH_SIGNING_KEY={{ jwt_refresh_signing_key }}
      - MARKPOST_ADMIN__INITIAL_USERNAME={{ admin_username }}
      - MARKPOST_ADMIN__INITIAL_PASSWORD={{ admin_password }}
    depends_on:
      postgres:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://127.0.0.1:{{ backend_port }}/api/v1/health"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 30s
    restart: always

  postgres:
    image: postgres:17-alpine
    container_name: {{ app_name }}-postgres
    ports:
      - "{{ postgres_port }}:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    environment:
      - POSTGRES_DB={{ postgres_db }}
      - POSTGRES_USER={{ postgres_user }}
      - POSTGRES_PASSWORD={{ postgres_password }}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ postgres_user }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: always

volumes:
  pgdata:
    name: {{ app_name }}_pgdata
